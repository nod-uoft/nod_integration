.navbar-brand:hover .nod-logo{
  filter: alpha(opacity=100);
  opacity: 1;
}

.navbar-brand .nod-logo::before {
  content: "";
  display: inline-block;
  width: 1.5rem;
  height: 3rem;
  background-image: url("<%= asset_path('nod_integration/nod-logo-white-trans-h300.png') %>");
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
	margin-left: 0.75rem;
  vertical-align: middle;
}